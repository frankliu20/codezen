{
  "name": "codezen",
  "displayName": "CodeZen - Coding Merit Tracker",
  "description": "Turn every keystroke into merit. A mindful coding companion for VS Code. 写代码攒功德，把编码变成修行。",
  "version": "0.1.3",
  "license": "MIT",
  "publisher": "frankliu20",
  "author": {
    "name": "Frank Liu"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "merit",
    "wooden fish",
    "木鱼",
    "功德",
    "zen",
    "mindful",
    "coding",
    "fun",
    "productivity"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/frankliu20/codezen"
  },
  "homepage": "https://github.com/frankliu20/codezen#readme",
  "bugs": {
    "url": "https://github.com/frankliu20/codezen/issues"
  },
  "contributes": {
    "commands": [
      {
        "command": "codezen.showMeritBook",
        "title": "CodeZen: Show Merit Book"
      },
      {
        "command": "codezen.toggleSound",
        "title": "CodeZen: Toggle Sound"
      },
      {
        "command": "codezen.reset",
        "title": "CodeZen: Reset Merit"
      },
      {
        "command": "codezen.toggleMuyu",
        "title": "CodeZen: Toggle Muyu Panel"
      }
    ],
    "viewsContainers": {
      "panel": [
        {
          "id": "codezen-panel",
          "title": "CodeZen",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "codezen-panel": [
        {
          "type": "webview",
          "id": "codezen.muyuView",
          "name": "🪵 Muyu"
        }
      ]
    },
    "configuration": {
      "title": "CodeZen",
      "properties": {
        "codezen.sound.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable wooden fish sound effect on keystroke"
        },
        "codezen.sound.probability": {
          "type": "number",
          "default": 0.01,
          "minimum": 0,
          "maximum": 1,
          "description": "Probability of sound playing per keystroke (0-1)"
        },
        "codezen.statusBar.format": {
          "type": "string",
          "default": "🪵 {merit}",
          "description": "Status bar display format. Use {merit} for count, {rank} for title"
        },
        "codezen.locale": {
          "type": "string",
          "default": "auto",
          "enum": [
            "auto",
            "en",
            "zh-CN"
          ],
          "description": "Display language (auto follows VS Code language)"
        },
        "codezen.agent.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Count AI agent / multi-character input as merit"
        },
        "codezen.agent.weight": {
          "type": "number",
          "default": 10,
          "minimum": 1,
          "maximum": 1000,
          "description": "Characters per 1 merit for AI agent input (e.g. 10 = 1 merit per 10 characters)"
        },
        "codezen.agent.maxPerMinute": {
          "type": "number",
          "default": 600,
          "minimum": 1,
          "maximum": 10000,
          "description": "Maximum agent merit per minute (rate limit)"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  }
}
